# gridiron_gpt/diagnostics/diagnostics.xsh — GridIron GPT Diagnostics Module 🧪

from xonsh.tools import which
from datetime import datetime
import os

env = __xonsh__.env

# 🛡️ Defensive session guard
if env.get("GRIDIRON_SESSION_STARTED"):
    print(f"{env.get('EMOJI_WARN', '🛡️')} Session already started — skipping diagnostics.xsh.")
    raise SystemExit

# 🛡️ Prevent duplicate diagnostics
if env.get("__GRIDIRON_DIAGNOSTICS_RUN__"):
    print(f"{env.get('EMOJI_TRACE', '🧠')} Diagnostics already run — skipping.")
    raise SystemExit

env["__GRIDIRON_DIAGNOSTICS_RUN__"] = True

# 🕒 Timestamp and user
timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
user = env.get("USER", "unknown")

# 📜 Log sourcing fingerprint
log_path = os.path.expanduser("~/projects/my_project/gridiron_gpt/logs/source_trace.log")
try:
    with open(log_path, "a") as f:
        f.write(f"[{timestamp}] diagnostics.xsh sourced by {user}\n")
except Exception as e:
    print(f"{env.get('EMOJI_WARN', '⚠️')} Failed to write sourcing log: {e}")

# 🩺 Visual banner
print("╔════════════════════════════════════════════════════╗")
print("║ 🩺 GridIron GPT — Diagnostics Module               ║")
print("║ Logs shell health, sourcing order, and env state   ║")
print("╚════════════════════════════════════════════════════╝")

# 🧪 Tool checks
def check_tool(name):
    if which(name):
        print(f"🔧 {name}: {env.get('EMOJI_SUCCESS', '✅')} Found")
    else:
        print(f"🔧 {name}: {env.get('EMOJI_FAIL', '❌')} Missing")

for tool in ['python3', 'git', 'nvim']:
    check_tool(tool)

# 🧠 Shell version
xonsh_version = env.get("XONSH_VERSION", "unknown")
print(f"🧠 Xonsh version: {xonsh_version}")

# 📦 Virtual Environment Check
venv = env.get("VIRTUAL_ENV")
PHREDENV_ACTIVE = bool(venv)

if PHREDENV_ACTIVE:
    print(f"📦 Virtual environment: {venv}")
    print(f"{env.get('EMOJI_SUCCESS', '🧪')} Environment confirmed — diagnostics can proceed.")
else:
    print(f"📦 Virtual environment: {env.get('EMOJI_FAIL', '❌')} Not active")
    print(f"{env.get('EMOJI_WARN', '⚠️')} Contributors may need to run setup.")

# 🕒 Completion timestamp
completion_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
print(f"🕒 Diagnostics completed at: {completion_time}")
print("══════════════════════════════════════════════════════")
print(f"{env.get('EMOJI_TRACE', '🩺')} Welcome to your shell session!")
